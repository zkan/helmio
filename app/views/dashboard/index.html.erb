<div class="p-6">
  <h1 class="text-2xl font-bold mb-6">Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Monthly Gross Profit</p>
      <p class="text-3xl font-bold text-green-600"><%= number_to_currency(@totals[:gross_profit], unit: "THB", format: "%u %n", precision: 0) %></p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Monthly Revenue</p>
      <p class="text-3xl font-bold text-blue-600"><%= number_to_currency(@totals[:revenue], unit: "THB", format: "%u %n", precision: 0) %></p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Monthly Margin</p>
      <p class="text-3xl font-bold text-purple-600"><%= number_to_percentage(@totals[:margin], precision: 1) %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Yearly Gross Profit</p>
      <p class="text-2xl font-bold text-green-600"><%= number_to_currency(@totals[:yearly_gross_profit], unit: "THB", format: "%u %n", precision: 0) %></p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Yearly Revenue</p>
      <p class="text-2xl font-bold text-blue-600"><%= number_to_currency(@totals[:yearly_revenue], unit: "THB", format: "%u %n", precision: 0) %></p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <p class="text-sm text-gray-500">Yearly Margin</p>
      <p class="text-2xl font-bold text-purple-600"><%= number_to_percentage(@totals[:yearly_margin], precision: 1) %></p>
    </div>
  </div>

  <h2 class="text-xl font-bold mb-4">By Site</h2>
  <div class="grid grid-cols-1 gap-6">
    <% @sites.each do |site_data| %>
      <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="text-lg font-semibold mb-4"><%= site_data[:site].name %></h3>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <p class="text-sm text-gray-500">Monthly Gross Profit</p>
            <p class="text-xl font-bold text-green-600"><%= number_to_currency(site_data[:gross_profit], unit: "THB", format: "%u %n", precision: 0) %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Monthly Revenue</p>
            <p class="text-xl font-bold text-blue-600"><%= number_to_currency(site_data[:revenue], unit: "THB", format: "%u %n", precision: 0) %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Monthly Margin</p>
            <p class="text-xl font-bold text-purple-600"><%= number_to_percentage(site_data[:margin], precision: 1) %></p>
          </div>
        </div>
        <% if site_data[:crews].any? %>
          <div class="mt-4">
            <button type="button" onclick="this.nextElementSibling.classList.toggle('hidden'); this.textContent = this.nextElementSibling.classList.contains('hidden') ? 'Show crews (<%= site_data[:crews].size %>)' : 'Hide crews'" class="text-sm text-blue-600 hover:text-blue-800 underline">
              Show crews (<%= site_data[:crews].size %>)
            </button>
            <div class="hidden mt-2 p-3 bg-gray-50 rounded border">
              <table class="text-sm w-full">
                <thead>
                  <tr class="text-left text-gray-500">
                    <th class="pb-2">Crew</th>
                    <th class="pb-2">Man Day Rate</th>
                    <th class="pb-2">Rate Card Price</th>
                  </tr>
                </thead>
                <tbody>
                  <% site_data[:crews].sort_by(&:man_day_rate).reverse.each do |crew| %>
                    <tr>
                      <td class="py-1"><%= crew.name %></td>
                      <td class="py-1"><%= number_to_currency(crew.man_day_rate, unit: "THB", format: "%u %n", precision: 0) %></td>
                      <td class="py-1"><% rate_item = crew.crew_rate_card_items.find { |crc| crc.rate_card_item.rate_card.site == site_data[:site] }&.rate_card_item %><%= rate_item ? number_to_currency(rate_item.price, unit: "THB", format: "%u %n", precision: 0) : '-' %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>